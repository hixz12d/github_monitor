# --- GitHub Subscribe Bot (.env example) ---
# Copy this file to `.env` and fill your own secrets.
# - Linux/macOS:  cp .env.example .env
# - PowerShell:   Copy-Item .env.example .env
#
# ⚠️ Do NOT commit `.env` to git.

# --- Telegram (required) ---
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234
TELEGRAM_CHAT_ID=@my_channel

# Optional: where you send admin commands like /subscribe, /list, /check, etc.
# - numeric id: -1001234567890 (groups/channels often start with -100)
# - username:   @your_username
# Defaults to TELEGRAM_CHAT_ID when not set.
# TELEGRAM_ADMIN_CHAT_ID=

# Optional: disable the long-polling command loop (daemon mode only)
# TELEGRAM_COMMANDS=1

# --- AI provider (required) ---
AI_PROVIDER=openai-completions
AI_API_KEY=sk-your-key
AI_MODEL=gpt-4o-mini

# Optional: OpenAI-compatible base URL (proxy/self-hosted). Example:
# AI_BASE_URL=https://api.openai.com/v1

# --- GitHub (optional but recommended) ---
# Personal Access Token (PAT). Increases REST API limit to ~5000 req/hr per user.
# GITHUB_TOKEN=ghp_your_token

# --- Subscriptions (required: choose ONE approach) ---
# Approach A: set SUBSCRIBE_REPOS
SUBSCRIBE_REPOS=vuejs/core,nodejs/node

# Approach B: use subscriptions file (takes priority if exists)
# SUBSCRIPTIONS_PATH=./data/subscriptions.json

# --- Scheduler (required for Docker/local daemon mode) ---
TIMEZONE=Asia/Shanghai
CRON=0 */10 9-23 * * *
TARGET_LANG=English

# --- Optional: Docker/Compose version compare (/status) ---
# Only needed if you mount Docker socket into the container.
# Default on Linux: /var/run/docker.sock
# DOCKER_SOCKET_PATH=/var/run/docker.sock

